{
  "name": "one-piece-tcg-online",
  "private": true,
  "version": "0.9.2",
  "type": "module",
  "description": "One Piece TCG web simulator. Pure rules engine + card/deck layer under /src/engine and /src/cards; React+Vite+Tailwind app shell under /src/app, /src/board, /src/animations, /src/renderer3d.",
  "scripts": {
    "dev": "vite",
    "dev:v2": "vite --mode v2",
    "build": "tsc --noEmit -p tsconfig.app.json && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.scripts.json",
    "test": "vitest run",
    "scrape": "tsx scripts/scrape/run.ts",
    "scrape:window": "node scripts/scrape/launch.mjs scrape",
    "scrape:limitless": "tsx scripts/scrape-limitless/run.ts",
    "scrape:limitless:window": "node scripts/scrape/launch.mjs scrape:limitless",
    "build:assets": "node scripts/build-card-assets.mjs && node scripts/generate-format-registry.mjs",
    "format:registry": "node scripts/generate-format-registry.mjs",
    "worklist": "tsx scripts/effect-worklist/run.ts",
    "coverage": "tsx scripts/effect-coverage/run.ts",
    "triage": "tsx scripts/effect-triage/run.ts",
    "triage:clusters": "node scripts/effect-triage-clusters.mjs",
    "effects:v2": "tsx scripts/effect-v2/run.ts",
    "effects:v2:uncovered": "tsx scripts/effect-v2/uncovered.ts",
    "audit:curation": "tsx scripts/curation-audit/run.ts",
    "scan:partials": "tsx scripts/partial-curation-scan/run.ts",
    "capability:doc": "tsx scripts/capability-doc/run.ts",
    "upload:blob-assets": "node scripts/upload-blob-assets.mjs"
  },
  "dependencies": {
    "@colyseus/sdk": "^0.17.43",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.185.0",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.5.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.185.0",
    "@vercel/blob": "^1.1.1",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.45",
    "tailwindcss": "^3.4.10",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "vitest": "^2.0.5"
  }
}
