# Backend environment. Copy to server/.env for local dev; set the same keys in
# the Cloud Run service config for production. NEVER commit real secrets.

# Cloud Run injects PORT automatically; 8080 is a safe local default.
PORT=8080

# development | production
NODE_ENV=development

# MongoDB Atlas connection string (include the db name in the path).
# mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/optcg?retryWrites=true&w=majority
MONGODB_URI=

# Secret used to sign/verify JWTs. Use a long random value (e.g. `openssl rand -hex 32`).
JWT_SECRET=

# JWT lifetime (zeit/ms format). Optional; defaults to 7d.
JWT_EXPIRES_IN=7d

# Allowed browser origin(s) for CORS + WebSocket. Comma-separate to allow more
# than one (e.g. production Vercel domain + localhost during dev).
# https://your-app.vercel.app,http://localhost:5173
CLIENT_ORIGIN=http://localhost:5173

# Ranked mode remains opt-in until seasons/indexes exist in this environment.
RANKED_ENABLED=false

# Player Profile system feature flag — opt-in until the unique-username
# index has been verified clean (no pre-existing duplicate usernames) and
# the profile collections/indexes have been created in this environment.
# See server/src/db/mongo.ts ensureIndexes().
PROFILE_ENABLED=false
